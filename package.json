{
  "name": "agentik-design",
  "version": "0.4.1",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "description": "Agentik Design — open-source design product by Agentik OS. Forked from nexu-io/open-design. Local-first, BYOK, deployable to Vercel. Powered by Convex + Clerk.",
  "license": "Apache-2.0",
  "author": "Agentik OS <x@agentik-os.com>",
  "homepage": "https://github.com/agentik-os/AgentikDesign",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentik-os/AgentikDesign.git"
  },
  "bugs": {
    "url": "https://github.com/agentik-os/AgentikDesign/issues"
  },
  "bin": {
    "od": "./apps/daemon/dist/cli.js",
    "agentik-design": "./apps/daemon/dist/cli.js"
  },
  "scripts": {
    "postinstall": "node ./scripts/postinstall.mjs",
    "tools-dev": "pnpm exec tools-dev",
    "tools-pack": "pnpm exec tools-pack",
    "guard": "tsx ./scripts/guard.ts",
    "i18n:check": "tsx ./scripts/i18n-check.ts",
    "sync:community-pets": "node --experimental-strip-types scripts/sync-community-pets.ts",
    "bake:community-pets": "node --experimental-strip-types scripts/bake-community-pets.ts",
    "seed:test-projects": "node --experimental-strip-types scripts/seed-test-projects.ts",
    "typecheck": "pnpm -r --workspace-concurrency=1 --if-present run typecheck && tsc -p scripts/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@agentik-design/tools-dev": "workspace:*",
    "@agentik-design/tools-pack": "workspace:*",
    "@types/node": "^20.17.10",
    "convex": "^1.17.4",
    "tsx": "4.21.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": "~24",
    "pnpm": ">=10.33.2 <11"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}
